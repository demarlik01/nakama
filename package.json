{
  "name": "agent-for-work",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native AI teammate platform",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "latest",
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@slack/bolt": "^4.x",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.x",
    "croner": "^10.0.1",
    "express": "^4.x",
    "yaml": "^2.x"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.x",
    "@types/node": "^22.x",
    "tsx": "^4.x",
    "typescript": "^5.x",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}