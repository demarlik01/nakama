{
  "name": "agent-for-work",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native AI teammate platform",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
