    "express": "^4.x",
    "yaml": "^2.x",
    "chokidar": "^4.x"
  },
  "devDependencies": {
    "typescript": "^5.x",
    "tsx": "^4.x",
    "@types/node": "^22.x",
    "@types/express": "^4.x"
  }
}
